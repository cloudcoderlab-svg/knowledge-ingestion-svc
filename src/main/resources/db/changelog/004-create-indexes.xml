<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
    http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <!-- ============================================================================ -->
    <!-- Database Indexes - Performance Optimization                                 -->
    <!-- ============================================================================ -->
    <!-- This changelog creates unique and performance indexes for all tables         -->
    <!-- in the KNOWLEDGE schema to optimize query performance.                       -->
    <!-- ============================================================================ -->

    <!-- ========================================================================== -->
    <!-- Unique Indexes - Prevent Duplicates                                       -->
    <!-- ========================================================================== -->

    <changeSet id="004-create-unique-indexes" author="system">
        <createIndex schemaName="knowledge" indexName="ux_ingestion_documents_source_hash" tableName="ingestion_documents" unique="true">
            <column name="project_id"/>
            <column name="source_bucket"/>
            <column name="source_object"/>
            <column name="content_hash"/>
        </createIndex>
        <createIndex schemaName="knowledge" indexName="ux_artifacts_source_hash" tableName="artifacts" unique="true">
            <column name="project_id"/>
            <column name="source_bucket"/>
            <column name="source_object"/>
            <column name="content_hash"/>
        </createIndex>
        <createIndex schemaName="knowledge" indexName="ux_semantic_chunks_source_hash_index" tableName="semantic_chunks" unique="true">
            <column name="project_id"/>
            <column name="source_bucket"/>
            <column name="source_object"/>
            <column name="document_content_hash"/>
            <column name="chunk_index"/>
        </createIndex>
    </changeSet>

    <!-- ========================================================================== -->
    <!-- Performance Indexes - Query Optimization                                   -->
    <!-- ========================================================================== -->

    <changeSet id="004-create-performance-indexes-core" author="system">
        <!-- Core tables -->
        <createIndex schemaName="knowledge" indexName="ix_artifacts_project_source" tableName="artifacts">
            <column name="project_id"/>
            <column name="source_object"/>
        </createIndex>
        <createIndex schemaName="knowledge" indexName="ix_artifacts_current" tableName="artifacts">
            <column name="project_id"/>
            <column name="is_current"/>
        </createIndex>
        <createIndex schemaName="knowledge" indexName="ix_semantic_chunks_project_source" tableName="semantic_chunks">
            <column name="project_id"/>
            <column name="source_object"/>
            <column name="chunk_index"/>
        </createIndex>
        <createIndex schemaName="knowledge" indexName="ix_semantic_chunks_document" tableName="semantic_chunks">
            <column name="document_id"/>
        </createIndex>
        <createIndex schemaName="knowledge" indexName="ix_semantic_chunks_artifact" tableName="semantic_chunks">
            <column name="artifact_id"/>
        </createIndex>
    </changeSet>

    <changeSet id="004-create-performance-indexes-knowledge" author="system">
        <!-- Knowledge entity tables -->
        <createIndex schemaName="knowledge" indexName="ix_solution_components_project_artifact" tableName="solution_components">
            <column name="project_id"/>
            <column name="source_artifact_id"/>
        </createIndex>
        <createIndex schemaName="knowledge" indexName="ix_solution_components_project_name" tableName="solution_components">
            <column name="project_id"/>
            <column name="component_name"/>
        </createIndex>
        <createIndex schemaName="knowledge" indexName="ix_business_rules_project_artifact" tableName="business_rules">
            <column name="project_id"/>
            <column name="source_artifact_id"/>
        </createIndex>
        <createIndex schemaName="knowledge" indexName="ix_business_flows_project_artifact" tableName="business_flows">
            <column name="project_id"/>
            <column name="source_artifact_id"/>
        </createIndex>
        <createIndex schemaName="knowledge" indexName="ix_business_flow_steps_flow" tableName="business_flow_steps">
            <column name="flow_id"/>
            <column name="sequence_number"/>
        </createIndex>
        <createIndex schemaName="knowledge" indexName="ix_deployment_resources_project_artifact" tableName="deployment_resources">
            <column name="project_id"/>
            <column name="source_artifact_id"/>
        </createIndex>
        <createIndex schemaName="knowledge" indexName="ix_deployment_resources_project_env" tableName="deployment_resources">
            <column name="project_id"/>
            <column name="environment"/>
        </createIndex>
        <createIndex schemaName="knowledge" indexName="ix_deployment_resource_configs_resource" tableName="deployment_resource_configs">
            <column name="resource_id"/>
        </createIndex>
        <createIndex schemaName="knowledge" indexName="ix_knowledge_relationships_project_artifact" tableName="knowledge_relationships">
            <column name="project_id"/>
            <column name="source_artifact_id"/>
        </createIndex>
        <createIndex schemaName="knowledge" indexName="ix_knowledge_relationships_source" tableName="knowledge_relationships">
            <column name="project_id"/>
            <column name="source_type"/>
            <column name="source_ref_id"/>
        </createIndex>
        <createIndex schemaName="knowledge" indexName="ix_knowledge_relationships_target" tableName="knowledge_relationships">
            <column name="project_id"/>
            <column name="target_type"/>
            <column name="target_ref_id"/>
        </createIndex>
        <createIndex schemaName="knowledge" indexName="ix_knowledge_notes_project_artifact" tableName="knowledge_notes">
            <column name="project_id"/>
            <column name="source_artifact_id"/>
        </createIndex>
        <createIndex schemaName="knowledge" indexName="ix_usage_profiles_project_env" tableName="usage_profiles">
            <column name="project_id"/>
            <column name="environment"/>
        </createIndex>
        <createIndex schemaName="knowledge" indexName="ix_resource_cost_estimates_project_env" tableName="resource_cost_estimates">
            <column name="project_id"/>
            <column name="environment"/>
        </createIndex>
        <createIndex schemaName="knowledge" indexName="ix_resource_cost_estimates_resource" tableName="resource_cost_estimates">
            <column name="resource_id"/>
        </createIndex>
    </changeSet>

    <changeSet id="004-create-performance-indexes-business" author="system">
        <!-- Business layer tables -->
        <createIndex schemaName="knowledge" indexName="ix_business_roles_project" tableName="business_roles">
            <column name="project_id"/>
        </createIndex>
        <createIndex schemaName="knowledge" indexName="ix_business_users_project" tableName="business_users">
            <column name="project_id"/>
        </createIndex>
        <createIndex schemaName="knowledge" indexName="ix_business_capabilities_project" tableName="business_capabilities">
            <column name="project_id"/>
        </createIndex>
        <createIndex schemaName="knowledge" indexName="ix_business_decisions_project" tableName="business_decisions">
            <column name="project_id"/>
        </createIndex>
        <createIndex schemaName="knowledge" indexName="ix_business_decisions_workflow" tableName="business_decisions">
            <column name="workflow_id"/>
        </createIndex>
        <createIndex schemaName="knowledge" indexName="ix_business_terms_project" tableName="business_terms">
            <column name="project_id"/>
        </createIndex>
        <createIndex schemaName="knowledge" indexName="ix_business_policies_project" tableName="business_policies">
            <column name="project_id"/>
        </createIndex>
        <createIndex schemaName="knowledge" indexName="ix_business_metrics_project" tableName="business_metrics">
            <column name="project_id"/>
        </createIndex>
        <createIndex schemaName="knowledge" indexName="ix_business_metrics_capability" tableName="business_metrics">
            <column name="business_capability_id"/>
        </createIndex>
        <createIndex schemaName="knowledge" indexName="ix_business_flows_capability" tableName="business_flows">
            <column name="business_capability_id"/>
        </createIndex>
        <createIndex schemaName="knowledge" indexName="ix_business_rules_capability" tableName="business_rules">
            <column name="affects_business_capability"/>
        </createIndex>
    </changeSet>

    <!-- ========================================================================== -->
    <!-- PostgreSQL pgvector HNSW Indexes for RAG Semantic Search                  -->
    <!-- ========================================================================== -->
    <!-- HNSW (Hierarchical Navigable Small World) indexes for fast approximate    -->
    <!-- nearest neighbor search - optimized for RAG semantic search.              -->
    <!-- Parameters: m=16 (connections), ef_construction=64 (build quality)        -->
    <!-- Note: pgvector extension is enabled in 000-enable-pgvector.xml            -->
    <!-- ========================================================================== -->

    <changeSet id="004-create-vector-indexes" author="system">
        <sql>
            -- HNSW indexes for fast approximate nearest neighbor search (recommended for RAG)
            CREATE INDEX ix_semantic_chunks_embedding_hnsw
                ON knowledge.semantic_chunks
                USING hnsw (embedding vector_cosine_ops)
                WITH (m = 16, ef_construction = 64);

            CREATE INDEX ix_business_rules_embedding_hnsw
                ON knowledge.business_rules
                USING hnsw (embedding vector_cosine_ops)
                WITH (m = 16, ef_construction = 64);

            CREATE INDEX ix_business_flows_embedding_hnsw
                ON knowledge.business_flows
                USING hnsw (embedding vector_cosine_ops)
                WITH (m = 16, ef_construction = 64);

            CREATE INDEX ix_solution_components_embedding_hnsw
                ON knowledge.solution_components
                USING hnsw (embedding vector_cosine_ops)
                WITH (m = 16, ef_construction = 64);

            CREATE INDEX ix_business_capabilities_embedding_hnsw
                ON knowledge.business_capabilities
                USING hnsw (embedding vector_cosine_ops)
                WITH (m = 16, ef_construction = 64);

            CREATE INDEX ix_deployment_resources_embedding_hnsw
                ON knowledge.deployment_resources
                USING hnsw (embedding vector_cosine_ops)
                WITH (m = 16, ef_construction = 64);

            CREATE INDEX ix_knowledge_data_models_embedding_hnsw
                ON knowledge.knowledge_data_models
                USING hnsw (embedding vector_cosine_ops)
                WITH (m = 16, ef_construction = 64);

            CREATE INDEX ix_business_decisions_embedding_hnsw
                ON knowledge.business_decisions
                USING hnsw (embedding vector_cosine_ops)
                WITH (m = 16, ef_construction = 64);

            CREATE INDEX ix_business_terms_embedding_hnsw
                ON knowledge.business_terms
                USING hnsw (embedding vector_cosine_ops)
                WITH (m = 16, ef_construction = 64);

            CREATE INDEX ix_business_roles_embedding_hnsw
                ON knowledge.business_roles
                USING hnsw (embedding vector_cosine_ops)
                WITH (m = 16, ef_construction = 64);

            CREATE INDEX ix_business_users_embedding_hnsw
                ON knowledge.business_users
                USING hnsw (embedding vector_cosine_ops)
                WITH (m = 16, ef_construction = 64);

            CREATE INDEX ix_business_policies_embedding_hnsw
                ON knowledge.business_policies
                USING hnsw (embedding vector_cosine_ops)
                WITH (m = 16, ef_construction = 64);

            CREATE INDEX ix_business_metrics_embedding_hnsw
                ON knowledge.business_metrics
                USING hnsw (embedding vector_cosine_ops)
                WITH (m = 16, ef_construction = 64);

            CREATE INDEX ix_knowledge_relationships_embedding_hnsw
                ON knowledge.knowledge_relationships
                USING hnsw (embedding vector_cosine_ops)
                WITH (m = 16, ef_construction = 64);

            CREATE INDEX ix_knowledge_notes_embedding_hnsw
                ON knowledge.knowledge_notes
                USING hnsw (embedding vector_cosine_ops)
                WITH (m = 16, ef_construction = 64);

            CREATE INDEX ix_knowledge_data_fields_embedding_hnsw
                ON knowledge.knowledge_data_fields
                USING hnsw (embedding vector_cosine_ops)
                WITH (m = 16, ef_construction = 64);

            CREATE INDEX ix_business_flow_steps_embedding_hnsw
                ON knowledge.business_flow_steps
                USING hnsw (embedding vector_cosine_ops)
                WITH (m = 16, ef_construction = 64);
        </sql>
        <rollback>
            DROP INDEX IF EXISTS knowledge.ix_semantic_chunks_embedding_hnsw;
            DROP INDEX IF EXISTS knowledge.ix_business_rules_embedding_hnsw;
            DROP INDEX IF EXISTS knowledge.ix_business_flows_embedding_hnsw;
            DROP INDEX IF EXISTS knowledge.ix_solution_components_embedding_hnsw;
            DROP INDEX IF EXISTS knowledge.ix_business_capabilities_embedding_hnsw;
            DROP INDEX IF EXISTS knowledge.ix_deployment_resources_embedding_hnsw;
            DROP INDEX IF EXISTS knowledge.ix_knowledge_data_models_embedding_hnsw;
            DROP INDEX IF EXISTS knowledge.ix_business_decisions_embedding_hnsw;
            DROP INDEX IF EXISTS knowledge.ix_business_terms_embedding_hnsw;
            DROP INDEX IF EXISTS knowledge.ix_business_roles_embedding_hnsw;
            DROP INDEX IF EXISTS knowledge.ix_business_users_embedding_hnsw;
            DROP INDEX IF EXISTS knowledge.ix_business_policies_embedding_hnsw;
            DROP INDEX IF EXISTS knowledge.ix_business_metrics_embedding_hnsw;
            DROP INDEX IF EXISTS knowledge.ix_knowledge_relationships_embedding_hnsw;
            DROP INDEX IF EXISTS knowledge.ix_knowledge_notes_embedding_hnsw;
            DROP INDEX IF EXISTS knowledge.ix_knowledge_data_fields_embedding_hnsw;
            DROP INDEX IF EXISTS knowledge.ix_business_flow_steps_embedding_hnsw;
        </rollback>
    </changeSet>

</databaseChangeLog>
