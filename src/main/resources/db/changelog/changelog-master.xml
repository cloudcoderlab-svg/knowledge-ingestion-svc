<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
    http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="knowledge-engine-project-schema-v1" author="kengine">
        <validCheckSum>ANY</validCheckSum>
        <sqlFile
            path="db/changelog/sql/project-centered-schema.sql"
            relativeToChangelogFile="false"
            splitStatements="true"
            stripComments="false"/>
        <rollback>DROP SCHEMA IF EXISTS knowledge CASCADE;</rollback>
    </changeSet>

    <changeSet id="add-processing-summary-fields" author="kengine">
        <addColumn schemaName="knowledge" tableName="knowledge_engine_processes">
            <column name="total_tokens_processed" type="BIGINT">
                <constraints nullable="true"/>
            </column>
            <column name="total_bytes_processed" type="BIGINT">
                <constraints nullable="true"/>
            </column>
        </addColumn>
        <rollback>
            <dropColumn schemaName="knowledge" tableName="knowledge_engine_processes" columnName="total_tokens_processed"/>
            <dropColumn schemaName="knowledge" tableName="knowledge_engine_processes" columnName="total_bytes_processed"/>
        </rollback>
    </changeSet>

    <changeSet id="increase-varchar-lengths-for-business-rules" author="kengine">
        <modifyDataType schemaName="knowledge" tableName="knowledge_business_rules" columnName="rule_type" newDataType="VARCHAR(255)"/>
        <modifyDataType schemaName="knowledge" tableName="knowledge_business_rules" columnName="priority" newDataType="VARCHAR(100)"/>
        <rollback>
            <modifyDataType schemaName="knowledge" tableName="knowledge_business_rules" columnName="rule_type" newDataType="VARCHAR(100)"/>
            <modifyDataType schemaName="knowledge" tableName="knowledge_business_rules" columnName="priority" newDataType="VARCHAR(50)"/>
        </rollback>
    </changeSet>

    <changeSet id="increase-varchar-lengths-for-components-modules" author="kengine">
        <preConditions onFail="MARK_RAN">
            <columnExists schemaName="knowledge" tableName="knowledge_components" columnName="lifecycle"/>
        </preConditions>
        <modifyDataType schemaName="knowledge" tableName="knowledge_components" columnName="lifecycle" newDataType="VARCHAR(100)"/>
        <modifyDataType schemaName="knowledge" tableName="knowledge_modules" columnName="lifecycle" newDataType="VARCHAR(100)"/>
        <rollback>
            <modifyDataType schemaName="knowledge" tableName="knowledge_components" columnName="lifecycle" newDataType="VARCHAR(50)"/>
            <modifyDataType schemaName="knowledge" tableName="knowledge_modules" columnName="lifecycle" newDataType="VARCHAR(50)"/>
        </rollback>
    </changeSet>

    <changeSet id="add-project-id-to-workflow-steps-and-data-fields" author="kengine">
        <preConditions onFail="MARK_RAN">
            <not>
                <columnExists schemaName="knowledge" tableName="knowledge_workflow_steps" columnName="project_id"/>
            </not>
        </preConditions>

        <!-- Add project_id to knowledge_workflow_steps -->
        <addColumn schemaName="knowledge" tableName="knowledge_workflow_steps">
            <column name="project_id" type="UUID">
                <constraints nullable="true"/>
            </column>
        </addColumn>

        <!-- Populate project_id from parent workflow table -->
        <sql>
            UPDATE knowledge.knowledge_workflow_steps ws
            SET project_id = w.project_id
            FROM knowledge.knowledge_workflows w
            WHERE ws.workflow_id = w.workflow_id;
        </sql>

        <!-- Add NOT NULL constraint after populating -->
        <addNotNullConstraint schemaName="knowledge" tableName="knowledge_workflow_steps" columnName="project_id" columnDataType="UUID"/>

        <!-- Add foreign key constraint -->
        <addForeignKeyConstraint
            baseTableSchemaName="knowledge"
            baseTableName="knowledge_workflow_steps"
            baseColumnNames="project_id"
            constraintName="fk_workflow_steps_project"
            referencedTableSchemaName="knowledge"
            referencedTableName="projects"
            referencedColumnNames="project_id"
            onDelete="CASCADE"/>

        <!-- Add index for performance -->
        <createIndex schemaName="knowledge" tableName="knowledge_workflow_steps" indexName="idx_workflow_steps_project_id">
            <column name="project_id"/>
        </createIndex>

        <!-- Add project_id to knowledge_data_fields -->
        <addColumn schemaName="knowledge" tableName="knowledge_data_fields">
            <column name="project_id" type="UUID">
                <constraints nullable="true"/>
            </column>
        </addColumn>

        <!-- Populate project_id from parent data_models table -->
        <sql>
            UPDATE knowledge.knowledge_data_fields df
            SET project_id = dm.project_id
            FROM knowledge.knowledge_data_models dm
            WHERE df.data_model_id = dm.data_model_id;
        </sql>

        <!-- Add NOT NULL constraint after populating -->
        <addNotNullConstraint schemaName="knowledge" tableName="knowledge_data_fields" columnName="project_id" columnDataType="UUID"/>

        <!-- Add foreign key constraint -->
        <addForeignKeyConstraint
            baseTableSchemaName="knowledge"
            baseTableName="knowledge_data_fields"
            baseColumnNames="project_id"
            constraintName="fk_data_fields_project"
            referencedTableSchemaName="knowledge"
            referencedTableName="projects"
            referencedColumnNames="project_id"
            onDelete="CASCADE"/>

        <!-- Add index for performance -->
        <createIndex schemaName="knowledge" tableName="knowledge_data_fields" indexName="idx_data_fields_project_id">
            <column name="project_id"/>
        </createIndex>

        <rollback>
            <dropIndex schemaName="knowledge" tableName="knowledge_data_fields" indexName="idx_data_fields_project_id"/>
            <dropForeignKeyConstraint baseTableSchemaName="knowledge" baseTableName="knowledge_data_fields" constraintName="fk_data_fields_project"/>
            <dropColumn schemaName="knowledge" tableName="knowledge_data_fields" columnName="project_id"/>

            <dropIndex schemaName="knowledge" tableName="knowledge_workflow_steps" indexName="idx_workflow_steps_project_id"/>
            <dropForeignKeyConstraint baseTableSchemaName="knowledge" baseTableName="knowledge_workflow_steps" constraintName="fk_workflow_steps_project"/>
            <dropColumn schemaName="knowledge" tableName="knowledge_workflow_steps" columnName="project_id"/>
        </rollback>
    </changeSet>
</databaseChangeLog>

