<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
    http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <!-- ============================================================================ -->
    <!-- Business/Functional Layer - Business Requirements Capture                   -->
    <!-- ============================================================================ -->
    <!-- This changelog creates tables for capturing business/functional knowledge    -->
    <!-- to support knowledge extraction and requirements analysis from enterprise    -->
    <!-- systems. All entities include vector embeddings for RAG semantic search.     -->
    <!-- ============================================================================ -->

    <!-- ========================================================================== -->
    <!-- PART 1: Business Actors (WHO)                                             -->
    <!-- ========================================================================== -->

    <!-- Business Roles Table -->
    <changeSet id="003-create-business-roles-table" author="system">
        <createTable schemaName="knowledge" tableName="business_roles">
            <column name="business_role_id" type="uuid" defaultValueComputed="gen_random_uuid()">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="project_id" type="text">
                <constraints nullable="false"/>
            </column>
            <column name="role_name" type="varchar(255)">
                <constraints nullable="false"/>
            </column>
            <column name="role_type" type="varchar(100)"/>
            <column name="description" type="text"/>
            <column name="responsibilities" type="text"/>
            <column name="department" type="varchar(255)"/>
            <column name="business_capability" type="varchar(255)"/>
            <column name="source_artifact_id" type="varchar(36)"/>
            <column name="embedding" type="vector(768)" remarks="Vector embedding for RAG semantic search"/>
            <column name="created_at" type="timestamptz" defaultValueComputed="CURRENT_TIMESTAMP"/>
            <column name="updated_at" type="timestamptz" defaultValueComputed="CURRENT_TIMESTAMP"/>
        </createTable>
        <addForeignKeyConstraint
            baseTableSchemaName="knowledge"
            baseTableName="business_roles"
            baseColumnNames="project_id"
            constraintName="fk_business_role_project"
            referencedTableSchemaName="knowledge"
            referencedTableName="projects"
            referencedColumnNames="project_id"
            onDelete="CASCADE"/>
        <addForeignKeyConstraint
            baseTableSchemaName="knowledge"
            baseTableName="business_roles"
            baseColumnNames="source_artifact_id"
            constraintName="fk_business_role_artifact"
            referencedTableSchemaName="knowledge"
            referencedTableName="artifacts"
            referencedColumnNames="artifact_id"
            onDelete="SET NULL"/>
    </changeSet>

    <!-- Business Users/Personas Table -->
    <changeSet id="003-create-business-users-table" author="system">
        <createTable schemaName="knowledge" tableName="business_users">
            <column name="business_user_id" type="uuid" defaultValueComputed="gen_random_uuid()">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="project_id" type="text">
                <constraints nullable="false"/>
            </column>
            <column name="user_type" type="varchar(100)"/>
            <column name="persona" type="varchar(255)"/>
            <column name="needs" type="jsonb"/>
            <column name="pain_points" type="text"/>
            <column name="workflows_involved" type="jsonb"/>
            <column name="source_artifact_id" type="varchar(36)"/>
            <column name="embedding" type="vector(768)" remarks="Vector embedding for RAG semantic search"/>
            <column name="created_at" type="timestamptz" defaultValueComputed="CURRENT_TIMESTAMP"/>
            <column name="updated_at" type="timestamptz" defaultValueComputed="CURRENT_TIMESTAMP"/>
        </createTable>
        <addForeignKeyConstraint
            baseTableSchemaName="knowledge"
            baseTableName="business_users"
            baseColumnNames="project_id"
            constraintName="fk_business_user_project"
            referencedTableSchemaName="knowledge"
            referencedTableName="projects"
            referencedColumnNames="project_id"
            onDelete="CASCADE"/>
        <addForeignKeyConstraint
            baseTableSchemaName="knowledge"
            baseTableName="business_users"
            baseColumnNames="source_artifact_id"
            constraintName="fk_business_user_artifact"
            referencedTableSchemaName="knowledge"
            referencedTableName="artifacts"
            referencedColumnNames="artifact_id"
            onDelete="SET NULL"/>
    </changeSet>

    <!-- ========================================================================== -->
    <!-- PART 2: Business Capabilities (WHAT & WHY)                                -->
    <!-- ========================================================================== -->

    <!-- Business Capabilities Table -->
    <changeSet id="003-create-business-capabilities-table" author="system">
        <createTable schemaName="knowledge" tableName="business_capabilities">
            <column name="capability_id" type="uuid" defaultValueComputed="gen_random_uuid()">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="project_id" type="text">
                <constraints nullable="false"/>
            </column>
            <column name="capability_name" type="varchar(500)">
                <constraints nullable="false"/>
            </column>
            <column name="capability_type" type="varchar(100)"/>
            <column name="description" type="text"/>
            <column name="business_value" type="text"/>
            <column name="kpis" type="jsonb"/>
            <column name="supported_by_workflows" type="jsonb"/>
            <column name="supported_by_components" type="jsonb"/>
            <column name="business_owner" type="varchar(255)"/>
            <column name="source_artifact_id" type="varchar(36)"/>
            <column name="embedding" type="vector(768)" remarks="Vector embedding for RAG semantic search"/>
            <column name="created_at" type="timestamptz" defaultValueComputed="CURRENT_TIMESTAMP"/>
            <column name="updated_at" type="timestamptz" defaultValueComputed="CURRENT_TIMESTAMP"/>
        </createTable>
        <addForeignKeyConstraint
            baseTableSchemaName="knowledge"
            baseTableName="business_capabilities"
            baseColumnNames="project_id"
            constraintName="fk_business_capability_project"
            referencedTableSchemaName="knowledge"
            referencedTableName="projects"
            referencedColumnNames="project_id"
            onDelete="CASCADE"/>
        <addForeignKeyConstraint
            baseTableSchemaName="knowledge"
            baseTableName="business_capabilities"
            baseColumnNames="source_artifact_id"
            constraintName="fk_business_capability_artifact"
            referencedTableSchemaName="knowledge"
            referencedTableName="artifacts"
            referencedColumnNames="artifact_id"
            onDelete="SET NULL"/>
    </changeSet>

    <!-- Business Role to Workflow Assignments -->
    <changeSet id="003-create-business-role-workflows-table" author="system">
        <createTable schemaName="knowledge" tableName="business_role_workflows">
            <column name="assignment_id" type="uuid" defaultValueComputed="gen_random_uuid()">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="business_role_id" type="uuid">
                <constraints nullable="false"/>
            </column>
            <column name="workflow_id" type="varchar(36)">
                <constraints nullable="false"/>
            </column>
            <column name="involvement_type" type="varchar(100)"/>
            <column name="decision_authority" type="varchar(100)"/>
            <column name="created_at" type="timestamptz" defaultValueComputed="CURRENT_TIMESTAMP"/>
        </createTable>
        <addForeignKeyConstraint
            baseTableSchemaName="knowledge"
            baseTableName="business_role_workflows"
            baseColumnNames="business_role_id"
            constraintName="fk_role_workflow_role"
            referencedTableSchemaName="knowledge"
            referencedTableName="business_roles"
            referencedColumnNames="business_role_id"
            onDelete="CASCADE"/>
        <addForeignKeyConstraint
            baseTableSchemaName="knowledge"
            baseTableName="business_role_workflows"
            baseColumnNames="workflow_id"
            constraintName="fk_role_workflow_flow"
            referencedTableSchemaName="knowledge"
            referencedTableName="business_flows"
            referencedColumnNames="flow_id"
            onDelete="CASCADE"/>
    </changeSet>

    <!-- ========================================================================== -->
    <!-- PART 3: Business Decisions (DECISION POINTS)                              -->
    <!-- ========================================================================== -->

    <!-- Business Decisions Table -->
    <changeSet id="003-create-business-decisions-table" author="system">
        <createTable schemaName="knowledge" tableName="business_decisions">
            <column name="decision_id" type="uuid" defaultValueComputed="gen_random_uuid()">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="project_id" type="text">
                <constraints nullable="false"/>
            </column>
            <column name="decision_name" type="varchar(500)">
                <constraints nullable="false"/>
            </column>
            <column name="decision_question" type="text"/>
            <column name="decision_criteria" type="text"/>
            <column name="decision_maker_role" type="uuid"/>
            <column name="decision_options" type="jsonb"/>
            <column name="decision_context" type="text"/>
            <column name="workflow_id" type="varchar(36)"/>
            <column name="workflow_step_id" type="varchar(36)"/>
            <column name="source_artifact_id" type="varchar(36)"/>
            <column name="embedding" type="vector(768)" remarks="Vector embedding for RAG semantic search"/>
            <column name="created_at" type="timestamptz" defaultValueComputed="CURRENT_TIMESTAMP"/>
            <column name="updated_at" type="timestamptz" defaultValueComputed="CURRENT_TIMESTAMP"/>
        </createTable>
        <addForeignKeyConstraint
            baseTableSchemaName="knowledge"
            baseTableName="business_decisions"
            baseColumnNames="project_id"
            constraintName="fk_business_decision_project"
            referencedTableSchemaName="knowledge"
            referencedTableName="projects"
            referencedColumnNames="project_id"
            onDelete="CASCADE"/>
        <addForeignKeyConstraint
            baseTableSchemaName="knowledge"
            baseTableName="business_decisions"
            baseColumnNames="decision_maker_role"
            constraintName="fk_business_decision_role"
            referencedTableSchemaName="knowledge"
            referencedTableName="business_roles"
            referencedColumnNames="business_role_id"
            onDelete="SET NULL"/>
        <addForeignKeyConstraint
            baseTableSchemaName="knowledge"
            baseTableName="business_decisions"
            baseColumnNames="workflow_id"
            constraintName="fk_business_decision_workflow"
            referencedTableSchemaName="knowledge"
            referencedTableName="business_flows"
            referencedColumnNames="flow_id"
            onDelete="SET NULL"/>
        <addForeignKeyConstraint
            baseTableSchemaName="knowledge"
            baseTableName="business_decisions"
            baseColumnNames="workflow_step_id"
            constraintName="fk_business_decision_step"
            referencedTableSchemaName="knowledge"
            referencedTableName="business_flow_steps"
            referencedColumnNames="step_id"
            onDelete="SET NULL"/>
        <addForeignKeyConstraint
            baseTableSchemaName="knowledge"
            baseTableName="business_decisions"
            baseColumnNames="source_artifact_id"
            constraintName="fk_business_decision_artifact"
            referencedTableSchemaName="knowledge"
            referencedTableName="artifacts"
            referencedColumnNames="artifact_id"
            onDelete="SET NULL"/>
    </changeSet>

    <!-- ========================================================================== -->
    <!-- PART 4: Business Terms/Glossary (BUSINESS LANGUAGE)                       -->
    <!-- ========================================================================== -->

    <!-- Business Terms Table -->
    <changeSet id="003-create-business-terms-table" author="system">
        <createTable schemaName="knowledge" tableName="business_terms">
            <column name="term_id" type="uuid" defaultValueComputed="gen_random_uuid()">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="project_id" type="text">
                <constraints nullable="false"/>
            </column>
            <column name="term_name" type="varchar(255)">
                <constraints nullable="false"/>
            </column>
            <column name="business_definition" type="text"/>
            <column name="technical_definition" type="text"/>
            <column name="synonyms" type="jsonb"/>
            <column name="category" type="varchar(100)"/>
            <column name="business_owner" type="varchar(255)"/>
            <column name="used_in_workflows" type="jsonb"/>
            <column name="used_in_rules" type="jsonb"/>
            <column name="mapped_to_data_model" type="uuid"/>
            <column name="source_artifact_id" type="varchar(36)"/>
            <column name="embedding" type="vector(768)" remarks="Vector embedding for RAG semantic search"/>
            <column name="created_at" type="timestamptz" defaultValueComputed="CURRENT_TIMESTAMP"/>
            <column name="updated_at" type="timestamptz" defaultValueComputed="CURRENT_TIMESTAMP"/>
        </createTable>
        <addForeignKeyConstraint
            baseTableSchemaName="knowledge"
            baseTableName="business_terms"
            baseColumnNames="project_id"
            constraintName="fk_business_term_project"
            referencedTableSchemaName="knowledge"
            referencedTableName="projects"
            referencedColumnNames="project_id"
            onDelete="CASCADE"/>
        <addForeignKeyConstraint
            baseTableSchemaName="knowledge"
            baseTableName="business_terms"
            baseColumnNames="mapped_to_data_model"
            constraintName="fk_business_term_data_model"
            referencedTableSchemaName="knowledge"
            referencedTableName="knowledge_data_models"
            referencedColumnNames="data_model_id"
            onDelete="SET NULL"/>
        <addForeignKeyConstraint
            baseTableSchemaName="knowledge"
            baseTableName="business_terms"
            baseColumnNames="source_artifact_id"
            constraintName="fk_business_term_artifact"
            referencedTableSchemaName="knowledge"
            referencedTableName="artifacts"
            referencedColumnNames="artifact_id"
            onDelete="SET NULL"/>
    </changeSet>

    <!-- ========================================================================== -->
    <!-- PART 5: Business Policies (GOVERNANCE & COMPLIANCE)                       -->
    <!-- ========================================================================== -->

    <!-- Business Policies Table -->
    <changeSet id="003-create-business-policies-table" author="system">
        <createTable schemaName="knowledge" tableName="business_policies">
            <column name="policy_id" type="uuid" defaultValueComputed="gen_random_uuid()">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="project_id" type="text">
                <constraints nullable="false"/>
            </column>
            <column name="policy_name" type="varchar(500)">
                <constraints nullable="false"/>
            </column>
            <column name="policy_type" type="varchar(100)"/>
            <column name="description" type="text"/>
            <column name="business_rationale" type="text"/>
            <column name="regulatory_requirement" type="varchar(255)"/>
            <column name="enforcement_level" type="varchar(50)"/>
            <column name="implemented_by_rules" type="jsonb"/>
            <column name="implemented_by_workflows" type="jsonb"/>
            <column name="business_owner" type="varchar(255)"/>
            <column name="effective_date" type="date"/>
            <column name="source_artifact_id" type="varchar(36)"/>
            <column name="embedding" type="vector(768)" remarks="Vector embedding for RAG semantic search"/>
            <column name="created_at" type="timestamptz" defaultValueComputed="CURRENT_TIMESTAMP"/>
            <column name="updated_at" type="timestamptz" defaultValueComputed="CURRENT_TIMESTAMP"/>
        </createTable>
        <addForeignKeyConstraint
            baseTableSchemaName="knowledge"
            baseTableName="business_policies"
            baseColumnNames="project_id"
            constraintName="fk_business_policy_project"
            referencedTableSchemaName="knowledge"
            referencedTableName="projects"
            referencedColumnNames="project_id"
            onDelete="CASCADE"/>
        <addForeignKeyConstraint
            baseTableSchemaName="knowledge"
            baseTableName="business_policies"
            baseColumnNames="source_artifact_id"
            constraintName="fk_business_policy_artifact"
            referencedTableSchemaName="knowledge"
            referencedTableName="artifacts"
            referencedColumnNames="artifact_id"
            onDelete="SET NULL"/>
    </changeSet>

    <!-- ========================================================================== -->
    <!-- PART 6: Business Metrics/KPIs (SUCCESS MEASURES)                          -->
    <!-- ========================================================================== -->

    <!-- Business Metrics Table -->
    <changeSet id="003-create-business-metrics-table" author="system">
        <createTable schemaName="knowledge" tableName="business_metrics">
            <column name="metric_id" type="uuid" defaultValueComputed="gen_random_uuid()">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="project_id" type="text">
                <constraints nullable="false"/>
            </column>
            <column name="metric_name" type="varchar(500)">
                <constraints nullable="false"/>
            </column>
            <column name="metric_type" type="varchar(100)"/>
            <column name="description" type="text"/>
            <column name="calculation_method" type="text"/>
            <column name="target_value" type="varchar(100)"/>
            <column name="measured_by_workflow" type="varchar(36)"/>
            <column name="measured_by_component" type="varchar(36)"/>
            <column name="business_capability_id" type="uuid"/>
            <column name="source_artifact_id" type="varchar(36)"/>
            <column name="embedding" type="vector(768)" remarks="Vector embedding for RAG semantic search"/>
            <column name="created_at" type="timestamptz" defaultValueComputed="CURRENT_TIMESTAMP"/>
            <column name="updated_at" type="timestamptz" defaultValueComputed="CURRENT_TIMESTAMP"/>
        </createTable>
        <addForeignKeyConstraint
            baseTableSchemaName="knowledge"
            baseTableName="business_metrics"
            baseColumnNames="project_id"
            constraintName="fk_business_metric_project"
            referencedTableSchemaName="knowledge"
            referencedTableName="projects"
            referencedColumnNames="project_id"
            onDelete="CASCADE"/>
        <addForeignKeyConstraint
            baseTableSchemaName="knowledge"
            baseTableName="business_metrics"
            baseColumnNames="measured_by_workflow"
            constraintName="fk_business_metric_workflow"
            referencedTableSchemaName="knowledge"
            referencedTableName="business_flows"
            referencedColumnNames="flow_id"
            onDelete="SET NULL"/>
        <addForeignKeyConstraint
            baseTableSchemaName="knowledge"
            baseTableName="business_metrics"
            baseColumnNames="measured_by_component"
            constraintName="fk_business_metric_component"
            referencedTableSchemaName="knowledge"
            referencedTableName="solution_components"
            referencedColumnNames="component_id"
            onDelete="SET NULL"/>
        <addForeignKeyConstraint
            baseTableSchemaName="knowledge"
            baseTableName="business_metrics"
            baseColumnNames="business_capability_id"
            constraintName="fk_business_metric_capability"
            referencedTableSchemaName="knowledge"
            referencedTableName="business_capabilities"
            referencedColumnNames="capability_id"
            onDelete="SET NULL"/>
        <addForeignKeyConstraint
            baseTableSchemaName="knowledge"
            baseTableName="business_metrics"
            baseColumnNames="source_artifact_id"
            constraintName="fk_business_metric_artifact"
            referencedTableSchemaName="knowledge"
            referencedTableName="artifacts"
            referencedColumnNames="artifact_id"
            onDelete="SET NULL"/>
    </changeSet>

    <!-- ========================================================================== -->
    <!-- PART 7: Enhance Existing Tables with Business Context                     -->
    <!-- ========================================================================== -->

    <!-- Enhance business_flows with business context -->
    <changeSet id="003-enhance-business-flows" author="system">
        <addColumn schemaName="knowledge" tableName="business_flows">
            <column name="business_purpose" type="text" remarks="Why this workflow exists"/>
            <column name="business_capability_id" type="uuid" remarks="Which capability it supports"/>
            <column name="business_value" type="text" remarks="Value delivered to business"/>
            <column name="business_frequency" type="varchar(50)" remarks="How often used (daily, weekly, monthly)"/>
            <column name="business_volume" type="varchar(50)" remarks="Transaction volume (low, medium, high)"/>
            <column name="business_criticality" type="varchar(50)" remarks="Business impact (critical, high, medium, low)"/>
            <column name="business_owner" type="varchar(255)" remarks="Who owns this process"/>
            <column name="initiated_by_role" type="uuid" remarks="Which business role starts this"/>
            <column name="success_criteria" type="text" remarks="What defines successful completion"/>
        </addColumn>
        <addForeignKeyConstraint
            baseTableSchemaName="knowledge"
            baseTableName="business_flows"
            baseColumnNames="business_capability_id"
            constraintName="fk_flow_capability"
            referencedTableSchemaName="knowledge"
            referencedTableName="business_capabilities"
            referencedColumnNames="capability_id"
            onDelete="SET NULL"/>
        <addForeignKeyConstraint
            baseTableSchemaName="knowledge"
            baseTableName="business_flows"
            baseColumnNames="initiated_by_role"
            constraintName="fk_flow_initiator"
            referencedTableSchemaName="knowledge"
            referencedTableName="business_roles"
            referencedColumnNames="business_role_id"
            onDelete="SET NULL"/>
    </changeSet>

    <!-- Enhance business_rules with business context -->
    <changeSet id="003-enhance-business-rules" author="system">
        <addColumn schemaName="knowledge" tableName="business_rules">
            <column name="business_rationale" type="text" remarks="Why this rule exists"/>
            <column name="business_impact" type="text" remarks="What happens if violated"/>
            <column name="rule_category" type="varchar(100)" remarks="validation, calculation, authorization, policy"/>
            <column name="business_owner" type="varchar(255)" remarks="Who defines/maintains this rule"/>
            <column name="regulatory_basis" type="text" remarks="Is this mandated by regulation?"/>
            <column name="exception_handling" type="text" remarks="Can this rule be overridden? By whom?"/>
            <column name="business_examples" type="text" remarks="Examples in business terms"/>
            <column name="affects_business_capability" type="uuid" remarks="Which capability does this support"/>
        </addColumn>
        <addForeignKeyConstraint
            baseTableSchemaName="knowledge"
            baseTableName="business_rules"
            baseColumnNames="affects_business_capability"
            constraintName="fk_rule_capability"
            referencedTableSchemaName="knowledge"
            referencedTableName="business_capabilities"
            referencedColumnNames="capability_id"
            onDelete="SET NULL"/>
    </changeSet>

    <!-- Enhance knowledge_data_models with business context -->
    <changeSet id="003-enhance-knowledge-data-models" author="system">
        <addColumn schemaName="knowledge" tableName="knowledge_data_models">
            <column name="business_name" type="varchar(500)" remarks="Business-friendly name"/>
            <column name="business_definition" type="text" remarks="What this means to business"/>
            <column name="business_owner" type="varchar(255)" remarks="Who owns this data"/>
            <column name="data_sensitivity" type="varchar(50)" remarks="PII, confidential, public"/>
            <column name="data_quality_requirements" type="text" remarks="Business expectations"/>
            <column name="business_usage" type="text" remarks="How business uses this data"/>
            <column name="master_data" type="boolean" defaultValueBoolean="false" remarks="Is this master data?"/>
            <column name="reference_data" type="boolean" defaultValueBoolean="false" remarks="Is this reference data?"/>
        </addColumn>
    </changeSet>

    <!-- Enhance knowledge_data_fields with business context -->
    <changeSet id="003-enhance-knowledge-data-fields" author="system">
        <addColumn schemaName="knowledge" tableName="knowledge_data_fields">
            <column name="business_name" type="varchar(255)" remarks="Business-friendly name"/>
            <column name="business_definition" type="text" remarks="What this field means"/>
            <column name="business_examples" type="text" remarks="Example values"/>
            <column name="business_rules" type="jsonb" remarks="Rules that apply to this field"/>
        </addColumn>
    </changeSet>

    <!-- Enhance knowledge_relationships with business context -->
    <changeSet id="003-enhance-knowledge-relationships" author="system">
        <addColumn schemaName="knowledge" tableName="knowledge_relationships">
            <column name="business_relationship_type" type="varchar(100)" remarks="approves, reviews, owns, uses_data_from, escalates_to"/>
            <column name="business_description" type="text" remarks="Describe relationship in business terms"/>
        </addColumn>
    </changeSet>

</databaseChangeLog>
