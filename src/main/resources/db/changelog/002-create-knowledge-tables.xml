<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
    http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <!-- ============================================================================ -->
    <!-- Knowledge Graph Tables - Technical Layer Entities                           -->
    <!-- ============================================================================ -->
    <!-- This changelog creates tables for storing extracted technical knowledge      -->
    <!-- entities in the KNOWLEDGE schema. All entities include vector embeddings     -->
    <!-- for RAG semantic search capabilities.                                        -->
    <!-- ============================================================================ -->

    <!-- Solution Components Table -->
    <changeSet id="002-create-solution-components-table" author="system">
        <createTable schemaName="knowledge" tableName="solution_components">
            <column name="component_id" type="varchar(36)">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="project_id" type="text">
                <constraints nullable="false"/>
            </column>
            <column name="domain" type="text"/>
            <column name="subdomain" type="text"/>
            <column name="component_layer" type="text">
                <constraints nullable="false"/>
            </column>
            <column name="component_name" type="text">
                <constraints nullable="false"/>
            </column>
            <column name="component_type" type="text">
                <constraints nullable="false"/>
            </column>
            <column name="capability" type="text"/>
            <column name="responsibility" type="text"/>
            <column name="technology" type="text"/>
            <column name="owner" type="text"/>
            <column name="lifecycle" type="text">
                <constraints nullable="false"/>
            </column>
            <column name="source_artifact_id" type="varchar(36)"/>
            <column name="source_chunk_id" type="varchar(36)"/>
            <column name="confidence" type="double precision"/>
            <column name="embedding" type="vector(768)" remarks="Vector embedding for RAG semantic search"/>
            <column name="created_at" type="timestamptz" defaultValueComputed="CURRENT_TIMESTAMP"/>
            <column name="updated_at" type="timestamptz" defaultValueComputed="CURRENT_TIMESTAMP"/>
        </createTable>
        <addForeignKeyConstraint
            baseTableSchemaName="knowledge"
            baseTableName="solution_components"
            baseColumnNames="project_id"
            constraintName="fk_solution_component_project"
            referencedTableSchemaName="knowledge"
            referencedTableName="projects"
            referencedColumnNames="project_id"
            onDelete="CASCADE"/>
        <addForeignKeyConstraint
            baseTableSchemaName="knowledge"
            baseTableName="solution_components"
            baseColumnNames="source_artifact_id"
            constraintName="fk_solution_component_artifact"
            referencedTableSchemaName="knowledge"
            referencedTableName="artifacts"
            referencedColumnNames="artifact_id"
            onDelete="SET NULL"/>
        <addForeignKeyConstraint
            baseTableSchemaName="knowledge"
            baseTableName="solution_components"
            baseColumnNames="source_chunk_id"
            constraintName="fk_solution_component_chunk"
            referencedTableSchemaName="knowledge"
            referencedTableName="semantic_chunks"
            referencedColumnNames="chunk_id"
            onDelete="SET NULL"/>
    </changeSet>

