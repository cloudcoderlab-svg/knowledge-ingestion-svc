<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
    http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <!-- Consolidated complete schema with all tables, knowledge graph, and entity alignments -->
    <changeSet id="001-complete-schema" author="kengine">
        <sqlFile
            path="db/changelog/sql/001-initial-schema.sql"
            relativeToChangelogFile="false"
            splitStatements="true"
            stripComments="false"/>
        <rollback>
            DROP SCHEMA IF EXISTS knowledge CASCADE;
        </rollback>
    </changeSet>

</databaseChangeLog>
